# DeepSeek API
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Free local vector database (Chroma)
VECTOR_DB_PATH=data/chroma
VECTOR_COLLECTION=books_rag

# Embedding & rerank model (local, free)
EMBED_MODEL=BAAI/bge-small-zh-v1.5
RERANK_MODEL=BAAI/bge-reranker-base

# Retrieval settings
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5
VECTOR_RECALL_K=30
BM25_RECALL_K=30
